# Copy to .env (never commit .env). Values with special chars must be quoted.

# ── AI translate/structure step (server-side only — never shipped to the browser)
# Used by POST /api/assist/build. Without it, the app still works: contractors
# build bids by hand (graceful degradation).
ANTHROPIC_API_KEY=your_key_here
# Model for the build step (optional; defaults to claude-sonnet-4-6).
# BT_AI_MODEL=claude-sonnet-4-6
# Per-user monthly cap on AI builds (cost guardrail; default 200).
# BT_AI_MONTHLY_CAP=200

# ── Secret used to sign private photo URLs. MUST be set to a long random string
# in production (otherwise a per-process fallback is used and links break on restart).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BT_SIGNING_SECRET=

# ── Subscriptions / payments (Stripe — server-side only). Optional: if unset,
# billing is disabled and every user has full access (no paywall). When set, new
# users get a free trial, then must subscribe to create/send new bids.
# STRIPE_SECRET_KEY=sk_live_or_test_xxx
# STRIPE_PRICE_ID=price_xxx               # the recurring monthly Price in Stripe
# STRIPE_WEBHOOK_SECRET=whsec_xxx         # from the Stripe webhook endpoint
# BT_TRIAL_DAYS=14                        # free-trial length (default 14)
# BT_PUBLIC_URL=https://app.bidtranslator.com  # used for Stripe success/return URLs

# ── QuickBooks Online (per-contractor sync). From your Intuit Developer app.
# Optional: unset = the QuickBooks feature is hidden. Add the redirect URI
# https://<your-domain>/api/quickbooks/callback in the Intuit app's Keys & OAuth.
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=
# QBO_ENVIRONMENT=sandbox   # 'sandbox' for Development keys, 'production' for live keys

# ── Universal voice dictation (optional). Wherever the browser's live speech API
# isn't available (notably iPhone Safari), the app records audio and transcribes it
# here. Unset = those devices fall back to typing. Uses OpenAI Whisper.
# OPENAI_API_KEY=
# BT_TRANSCRIBE_MODEL=whisper-1

# ── Follow Up Boss CRM (optional, founder-level). Pushes every contractor who
# signs up into YOUR Follow Up Boss as a person, sourced/tagged so they stay
# separate from your real-estate pipeline, plus lifecycle notes (onboarded,
# customer accepted, deposit collected, subscribed). Unset = no-op.
# FOLLOWUPBOSS_API_KEY=
# FOLLOWUPBOSS_SOURCE=Bidtranslator
# FOLLOWUPBOSS_TAG=Bidtranslator Contractor

# ── Confirmation fan-out (optional). When a customer signs/accepts a proposal we
# POST a JSON payload here so you can route it to email/SMS/Follow Up Boss (e.g.
# via Zapier/Make or your own handler). Unset = no external send (the contractor
# is still notified in-app).
# BT_NOTIFY_WEBHOOK=

# ── Founder dashboard (private analytics). Set to your email to unlock the
# "Founder" tab (live signups, funnel, per-contractor metrics) for that account
# only. Your own account is excluded from the contractor metrics.
# BT_ADMIN_EMAIL=you@example.com

# ── Server
# BT_PORT=4000
# BT_DATA_DIR=./data   # where the SQLite db + photos live
