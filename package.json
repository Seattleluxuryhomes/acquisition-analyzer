{
  "name": "bidtranslator",
  "version": "1.0.0",
  "description": "Bidtranslator — field notebook + bilingual bid builder for contractors (Phase 1)",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
