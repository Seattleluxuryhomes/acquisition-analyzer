# BidVoice configuration. Copy to .env (never commit real keys).

# The AI transaction coordinator. Without this, the app still runs — you just
# can't auto-build offers from speech (you can still edit forms by hand).
ANTHROPIC_API_KEY=

# Model for the coordinator (defaults to Claude Opus 4.8).
BIDVOICE_MODEL=claude-opus-4-8

# Port (Render/host sets PORT automatically).
PORT=8788

# Where the SQLite db + data live (defaults to ./data).
BIDVOICE_DATA_DIR=
