{
  "name": "voice-button-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Voice-first and push-button AI command center. A remote control for AI.",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.mjs",
    "start": "tsc --noEmit && vite build && node server/index.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "build": "tsc --noEmit && vite build",
    "build:extension": "tsc --noEmit && vite build && node scripts/pack-extension.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.1",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
