# Voice Button AI — Fable Execution Engine (server-side only)
# Copy to .env and fill in. NEVER commit a real key. The key stays on the
# server and is never sent to the browser.

# Anthropic API key. Without it, the engine runs in OFFLINE mode and returns
# the prompt for the user to run by hand (the app still works).
ANTHROPIC_API_KEY=

# Which model the engine uses. Defaults to claude-opus-4-8 (top-tier, available
# on any API account today). Set to claude-fable-5 once your org has Fable
# access + 30-day data retention. No code change needed — just this value.
VBAI_MODEL=claude-opus-4-8

# Port for the server (serves the built app + /api/run). Default 8787.
VBAI_PORT=8787

# Set to 1 to force the simulated engine locally (stream a canned result with
# no key and no network). Leave unset/0 in production.
VBAI_MOCK=

# Note: Claude Fable 5 requires 30-day data retention on your Anthropic org
# (it is not available under zero-data-retention). Configure this in the
# Anthropic Console before going live, or requests will 400.
